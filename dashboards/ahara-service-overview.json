{
  "id": null,
  "uid": "ahara-service-overview",
  "title": "Ahara Telemetry Overview",
  "tags": ["ahara", "otel", "telemetry"],
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "schemaVersion": 39,
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "service",
        "label": "Service",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "victoriametrics"
        },
        "query": "label_values(service_name)",
        "includeAll": true,
        "multi": true,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        },
        "allValue": ".*",
        "refresh": 2
      },
      {
        "name": "namespace",
        "label": "Namespace",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "victoriametrics"
        },
        "query": "label_values(service_namespace)",
        "includeAll": true,
        "multi": true,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        },
        "allValue": ".*",
        "refresh": 2
      },
      {
        "name": "operation_type",
        "label": "Operation Type",
        "type": "custom",
        "query": "user_interaction,polling,background,health,system",
        "includeAll": true,
        "multi": true,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        },
        "allValue": ".*"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "HTTP Requests/sec",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "victoriametrics"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(ahara_http_server_request_count_total{service_name=~\"$service\",operation_type=~\"$operation_type\"}[$__rate_interval]))",
          "legendFormat": "requests/sec"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "decimals": 2
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        },
        "colorMode": "value",
        "graphMode": "area"
      }
    },
    {
      "id": 2,
      "title": "HTTP Error Rate",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "victoriametrics"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(ahara_http_server_request_count_total{service_name=~\"$service\",operation_type=~\"$operation_type\",operation_outcome=\"failed\"}[$__rate_interval])) / clamp_min(sum(rate(ahara_http_server_request_count_total{service_name=~\"$service\",operation_type=~\"$operation_type\"}[$__rate_interval])), 1)",
          "legendFormat": "error rate"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.02
              },
              {
                "color": "red",
                "value": 0.05
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        },
        "colorMode": "value",
        "graphMode": "area"
      }
    },
    {
      "id": 3,
      "title": "HTTP p95 Latency",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "victoriametrics"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 0
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum(rate(ahara_http_server_request_duration_ms_bucket{service_name=~\"$service\",operation_type=~\"$operation_type\"}[$__rate_interval])) by (le))",
          "legendFormat": "p95"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "decimals": 0
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        },
        "colorMode": "value",
        "graphMode": "area"
      }
    },
    {
      "id": 4,
      "title": "Lambda Invocations/sec",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "victoriametrics"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 0
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(ahara_faas_invocation_count_total{service_name=~\"$service\"}[$__rate_interval]))",
          "legendFormat": "invocations/sec"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "decimals": 2
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        },
        "colorMode": "value",
        "graphMode": "area"
      }
    },
    {
      "id": 5,
      "title": "App Work/sec",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "victoriametrics"
      },
      "gridPos": {
        "h": 4,
        "w": 12,
        "x": 0,
        "y": 4
      },
      "targets": [
        {
          "refId": "A",
          "expr": "(sum(rate(ahara_operation_count_total{service_name=~\"$service\",operation_type=~\"$operation_type\"}[$__rate_interval])) or vector(0)) + (sum(rate({__name__=~\"house_sensors_(backend_connections|collection_loops|device_validation|discovery_runs|influx_writes|job_cycles|poll_results)_total\",service_name=~\"$service\",service_namespace=~\"$namespace\",operation_type=~\"$operation_type\"}[$__rate_interval])) or vector(0))",
          "legendFormat": "work/sec"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "decimals": 2
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        },
        "colorMode": "value",
        "graphMode": "area"
      }
    },
    {
      "id": 6,
      "title": "Failed App Events",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "victoriametrics"
      },
      "gridPos": {
        "h": 4,
        "w": 12,
        "x": 12,
        "y": 4
      },
      "targets": [
        {
          "refId": "A",
          "expr": "(sum(increase(ahara_operation_count_total{service_name=~\"$service\",operation_type=~\"$operation_type\",operation_outcome=\"failed\"}[$__range])) or vector(0)) + (sum(increase({__name__=~\"house_sensors_(backend_connections|collection_loops|device_validation|discovery_runs|influx_writes|job_cycles|poll_results)_total\",service_name=~\"$service\",service_namespace=~\"$namespace\",operation_type=~\"$operation_type\",outcome=~\"error|invalid|misconfigured\"}[$__range])) or vector(0))",
          "legendFormat": "failed"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        },
        "colorMode": "value",
        "graphMode": "area"
      }
    },
    {
      "id": 7,
      "title": "HTTP Requests by Service",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "victoriametrics"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(ahara_http_server_request_count_total{service_name=~\"$service\",operation_type=~\"$operation_type\"}[$__rate_interval])) by (service_name)",
          "legendFormat": "{{service_name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        },
        "overrides": []
      }
    },
    {
      "id": 8,
      "title": "Work by Operation Type",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "victoriametrics"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(ahara_operation_count_total{service_name=~\"$service\",operation_type=~\"$operation_type\"}[$__rate_interval])) by (operation_type)",
          "legendFormat": "lambda {{operation_type}}"
        },
        {
          "refId": "B",
          "expr": "sum(rate({__name__=~\"house_sensors_(backend_connections|collection_loops|device_validation|discovery_runs|influx_writes|job_cycles|poll_results)_total\",service_name=~\"$service\",service_namespace=~\"$namespace\",operation_type=~\"$operation_type\"}[$__rate_interval])) by (operation_type)",
          "legendFormat": "local {{operation_type}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        },
        "overrides": []
      }
    },
    {
      "id": 9,
      "title": "Work by Service",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "victoriametrics"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 16
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(ahara_operation_count_total{service_name=~\"$service\",operation_type=~\"$operation_type\"}[$__rate_interval])) by (service_name)",
          "legendFormat": "{{service_name}}"
        },
        {
          "refId": "B",
          "expr": "sum(rate({__name__=~\"house_sensors_(backend_connections|collection_loops|device_validation|discovery_runs|influx_writes|job_cycles|poll_results)_total\",service_name=~\"$service\",service_namespace=~\"$namespace\",operation_type=~\"$operation_type\"}[$__rate_interval])) by (service_name)",
          "legendFormat": "{{service_name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        },
        "overrides": []
      }
    },
    {
      "id": 10,
      "title": "Outcomes",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "victoriametrics"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 16
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(ahara_operation_count_total{service_name=~\"$service\",operation_type=~\"$operation_type\"}[$__rate_interval])) by (operation_outcome)",
          "legendFormat": "lambda {{operation_outcome}}"
        },
        {
          "refId": "B",
          "expr": "sum(rate({__name__=~\"house_sensors_(backend_connections|collection_loops|device_validation|discovery_runs|influx_writes|job_cycles|poll_results)_total\",service_name=~\"$service\",service_namespace=~\"$namespace\",operation_type=~\"$operation_type\"}[$__rate_interval])) by (outcome)",
          "legendFormat": "local {{outcome}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        },
        "overrides": []
      }
    },
    {
      "id": 11,
      "title": "App Duration p95 by Service",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "victoriametrics"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 24
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum(rate(ahara_operation_duration_ms_bucket{service_name=~\"$service\",operation_type=~\"$operation_type\"}[$__rate_interval])) by (le, service_name))",
          "legendFormat": "{{service_name}} lambda"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.95, sum(rate({__name__=~\"house_sensors_.*_ms_bucket\",service_name=~\"$service\",service_namespace=~\"$namespace\",operation_type=~\"$operation_type\"}[$__rate_interval])) by (le, service_name))",
          "legendFormat": "{{service_name}} local"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms"
        },
        "overrides": []
      }
    },
    {
      "id": 12,
      "title": "Top App Events",
      "type": "table",
      "datasource": {
        "type": "prometheus",
        "uid": "victoriametrics"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 24
      },
      "targets": [
        {
          "refId": "A",
          "expr": "topk(20, sum(increase(ahara_operation_count_total{service_name=~\"$service\",operation_type=~\"$operation_type\"}[$__range])) by (service_name, operation_name, operation_type, operation_outcome))",
          "format": "table",
          "instant": true
        },
        {
          "refId": "B",
          "expr": "topk(20, sum(increase({__name__=~\"house_sensors_(backend_connections|collection_loops|device_validation|discovery_runs|influx_writes|job_cycles|poll_results)_total\",service_name=~\"$service\",service_namespace=~\"$namespace\",operation_type=~\"$operation_type\"}[$__range])) by (__name__, service_name, operation_type, outcome, job, backend))",
          "format": "table",
          "instant": true
        }
      ]
    }
  ]
}
