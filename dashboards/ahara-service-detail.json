{
  "id": null,
  "uid": "ahara-service-detail",
  "title": "Ahara Service Detail",
  "tags": ["ahara", "otel", "service"],
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "schemaVersion": 39,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "links": [
    {
      "title": "Ahara dashboards",
      "type": "dashboards",
      "tags": ["ahara"],
      "asDropdown": true,
      "includeVars": true,
      "keepTime": true,
      "icon": "apps"
    }
  ],
  "templating": {
    "list": [
      {
        "name": "service",
        "label": "Service",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "victoriametrics" },
        "definition": "label_values(ahara_operation_count_total, service_name)",
        "query": { "query": "label_values(ahara_operation_count_total, service_name)", "refId": "service" },
        "includeAll": false,
        "multi": false,
        "current": {},
        "refresh": 2,
        "sort": 1
      }
    ]
  },
  "panels": [
    {
      "id": 100,
      "type": "row",
      "title": "HTTP — $service",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "id": 1,
      "title": "Requests/sec",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "targets": [
        { "refId": "A", "expr": "sum(rate(ahara_http_server_request_count_total{service_name=\"$service\"}[$__rate_interval]))", "legendFormat": "req/sec" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps", "decimals": 2 }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" }
    },
    {
      "id": 2,
      "title": "5xx Error Rate",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "targets": [
        { "refId": "A", "expr": "sum(rate(ahara_http_server_request_count_total{service_name=\"$service\",http_response_status_code=~\"5..\"}[$__rate_interval])) / clamp_min(sum(rate(ahara_http_server_request_count_total{service_name=\"$service\"}[$__rate_interval])), 1)", "legendFormat": "5xx rate" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "decimals": 2, "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 0.02 }, { "color": "red", "value": 0.05 } ] } },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" }
    },
    {
      "id": 3,
      "title": "p95 Latency",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "targets": [
        { "refId": "A", "expr": "histogram_quantile(0.95, sum(rate(ahara_http_server_request_duration_ms_milliseconds_bucket{service_name=\"$service\"}[$__rate_interval])) by (le))", "legendFormat": "p95" }
      ],
      "fieldConfig": { "defaults": { "unit": "ms", "decimals": 0 }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" }
    },
    {
      "id": 4,
      "title": "FaaS Invocations/sec",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "targets": [
        { "refId": "A", "expr": "sum(rate(ahara_faas_invocation_count_total{service_name=\"$service\"}[$__rate_interval]))", "legendFormat": "inv/sec" }
      ],
      "fieldConfig": { "defaults": { "unit": "ops", "decimals": 2 }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" }
    },
    {
      "id": 5,
      "title": "Requests by Status Code",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 5 },
      "targets": [
        { "refId": "A", "expr": "sum(rate(ahara_http_server_request_count_total{service_name=\"$service\"}[$__rate_interval])) by (http_response_status_code)", "legendFormat": "{{http_response_status_code}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "fillOpacity": 30, "stacking": { "mode": "normal" }, "showPoints": "never" } }, "overrides": [] }
    },
    {
      "id": 6,
      "title": "HTTP Latency p50 / p95 / p99",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 5 },
      "targets": [
        { "refId": "A", "expr": "histogram_quantile(0.50, sum(rate(ahara_http_server_request_duration_ms_milliseconds_bucket{service_name=\"$service\"}[$__rate_interval])) by (le))", "legendFormat": "p50" },
        { "refId": "B", "expr": "histogram_quantile(0.95, sum(rate(ahara_http_server_request_duration_ms_milliseconds_bucket{service_name=\"$service\"}[$__rate_interval])) by (le))", "legendFormat": "p95" },
        { "refId": "C", "expr": "histogram_quantile(0.99, sum(rate(ahara_http_server_request_duration_ms_milliseconds_bucket{service_name=\"$service\"}[$__rate_interval])) by (le))", "legendFormat": "p99" }
      ],
      "fieldConfig": { "defaults": { "unit": "ms", "custom": { "fillOpacity": 0, "showPoints": "never" } }, "overrides": [] }
    },
    {
      "id": 7,
      "title": "Requests by Route",
      "type": "table",
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 13 },
      "targets": [
        { "refId": "A", "expr": "sum(rate(ahara_http_server_request_count_total{service_name=\"$service\"}[$__rate_interval])) by (http_request_method, url_path, http_response_status_code)", "format": "table", "instant": true }
      ],
      "transformations": [
        { "id": "organize", "options": { "excludeByName": { "Time": true }, "renameByName": { "http_request_method": "Method", "url_path": "Route", "http_response_status_code": "Status", "Value": "req/sec" } } },
        { "id": "sortBy", "options": { "fields": "", "sort": [ { "field": "req/sec", "desc": true } ] } }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps", "decimals": 3, "custom": { "filterable": true } }, "overrides": [] }
    },
    {
      "id": 200,
      "type": "row",
      "title": "Operations — $service",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 21 }
    },
    {
      "id": 8,
      "title": "Operations/sec by Name",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 22 },
      "targets": [
        { "refId": "A", "expr": "sum(rate(ahara_operation_count_total{service_name=\"$service\"}[$__rate_interval])) by (operation_name)", "legendFormat": "{{operation_name}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "fillOpacity": 10, "showPoints": "never" } }, "overrides": [] }
    },
    {
      "id": 9,
      "title": "Operation Outcomes",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 22 },
      "targets": [
        { "refId": "A", "expr": "sum(rate(ahara_operation_count_total{service_name=\"$service\"}[$__rate_interval])) by (operation_outcome)", "legendFormat": "{{operation_outcome}}" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops", "custom": { "fillOpacity": 30, "stacking": { "mode": "normal" }, "showPoints": "never" } },
        "overrides": [
          { "matcher": { "id": "byRegexp", "options": ".*(failed|error|invalid).*" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } } ] },
          { "matcher": { "id": "byRegexp", "options": ".*(succeeded|success).*" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } } ] }
        ]
      }
    },
    {
      "id": 10,
      "title": "Operation Duration Heatmap",
      "type": "heatmap",
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 30 },
      "targets": [
        { "refId": "A", "expr": "sum(rate(ahara_operation_duration_ms_milliseconds_bucket{service_name=\"$service\"}[$__rate_interval])) by (le)", "format": "heatmap", "legendFormat": "{{le}}" }
      ],
      "options": { "calculate": false, "cellGap": 1, "color": { "scheme": "Spectral", "mode": "scheme" }, "yAxis": { "unit": "ms" } },
      "fieldConfig": { "defaults": { "unit": "ms" }, "overrides": [] }
    },
    {
      "id": 11,
      "title": "FaaS Invocation Duration p95",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 30 },
      "targets": [
        { "refId": "A", "expr": "histogram_quantile(0.95, sum(rate(ahara_faas_invocation_duration_ms_milliseconds_bucket{service_name=\"$service\"}[$__rate_interval])) by (le, faas_name))", "legendFormat": "{{faas_name}} p95" }
      ],
      "fieldConfig": { "defaults": { "unit": "ms", "custom": { "fillOpacity": 0, "showPoints": "never" } }, "overrides": [] }
    },
    {
      "id": 300,
      "type": "row",
      "title": "Traces — $service",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 38 }
    },
    {
      "id": 12,
      "title": "Recent Traces",
      "type": "table",
      "datasource": { "type": "tempo", "uid": "tempo" },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 39 },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "tempo", "uid": "tempo" },
          "queryType": "traceqlSearch",
          "filters": [
            { "id": "service", "tag": "service.name", "operator": "=", "scope": "resource", "value": ["$service"], "valueType": "string" }
          ],
          "limit": 40,
          "tableType": "traces"
        }
      ],
      "fieldConfig": { "defaults": {}, "overrides": [] }
    },
    {
      "id": 13,
      "title": "Error Traces",
      "type": "table",
      "datasource": { "type": "tempo", "uid": "tempo" },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 39 },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "tempo", "uid": "tempo" },
          "queryType": "traceql",
          "query": "{ resource.service.name = \"$service\" && status = error }",
          "limit": 40,
          "tableType": "traces",
          "filters": []
        }
      ],
      "fieldConfig": { "defaults": {}, "overrides": [] }
    },
    {
      "id": 400,
      "type": "row",
      "title": "Logs — $service",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 48 }
    },
    {
      "id": 14,
      "title": "Recent Logs",
      "type": "logs",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 49 },
      "targets": [
        { "refId": "A", "expr": "{service_name=\"$service\"}" }
      ],
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      }
    }
  ]
}
