{
  "id": null,
  "uid": "bookmarker-operations",
  "title": "Bookmarker Operations",
  "tags": ["ahara", "bookmarker", "linkdrop"],
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "schemaVersion": 39,
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "links": [
    {
      "asDropdown": false,
      "icon": "external link",
      "includeVars": false,
      "keepTime": true,
      "targetBlank": false,
      "title": "Logs Drilldown",
      "tooltip": "Open Grafana's native log explorer for browsing labels, fields, volumes, and patterns.",
      "type": "link",
      "url": "/a/grafana-lokiexplore-app/explore"
    },
    {
      "asDropdown": false,
      "icon": "external link",
      "includeVars": false,
      "keepTime": true,
      "targetBlank": false,
      "title": "Linkdrop Logs Query",
      "tooltip": "Open the raw Loki query for Linkdrop services in Grafana Explore.",
      "type": "link",
      "url": "/explore?orgId=1&left=%7B%22datasource%22%3A%7B%22type%22%3A%22loki%22%2C%22uid%22%3A%22loki%22%7D%2C%22queries%22%3A%5B%7B%22refId%22%3A%22A%22%2C%22expr%22%3A%22%7Bservice_name%3D~%5C%22linkdrop.*%5C%22%7D%22%7D%5D%2C%22range%22%3A%7B%22from%22%3A%22now-6h%22%2C%22to%22%3A%22now%22%7D%7D"
    }
  ],
  "templating": {
    "list": [
      {
        "name": "operation_type",
        "label": "Operation Type",
        "type": "custom",
        "query": "user_interaction,polling,background,health",
        "includeAll": true,
        "multi": true,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        },
        "allValue": ".*"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "User Interactions/sec",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "victoriametrics"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(ahara_operation_count_total{service_name=~\"linkdrop.*\",operation_type=\"user_interaction\"}[$__rate_interval]))",
          "legendFormat": "user"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "decimals": 2
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        },
        "colorMode": "value",
        "graphMode": "area"
      }
    },
    {
      "id": 2,
      "title": "Polling/sec",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "victoriametrics"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(ahara_operation_count_total{service_name=~\"linkdrop.*\",operation_type=\"polling\"}[$__rate_interval]))",
          "legendFormat": "polling"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "decimals": 2
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        },
        "colorMode": "value",
        "graphMode": "area"
      }
    },
    {
      "id": 3,
      "title": "Image Upload Completion p95",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "victoriametrics"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 0
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum(rate(ahara_operation_duration_ms_bucket{service_name=~\"linkdrop.*\",operation_name=\"api.items.complete_image_upload\"}[$__rate_interval])) by (le))",
          "legendFormat": "p95"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "decimals": 0
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        },
        "colorMode": "value",
        "graphMode": "area"
      }
    },
    {
      "id": 4,
      "title": "Failed Operations",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "victoriametrics"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 0
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(ahara_operation_count_total{service_name=~\"linkdrop.*\",operation_outcome=\"failed\"}[$__range]))",
          "legendFormat": "failed"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "decimals": 0
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        },
        "colorMode": "value",
        "graphMode": "area"
      }
    },
    {
      "id": 5,
      "title": "Operation Rate",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "victoriametrics"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 4
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(ahara_operation_count_total{service_name=~\"linkdrop.*\",operation_type=~\"$operation_type\"}[$__rate_interval])) by (operation_name)",
          "legendFormat": "{{operation_name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        },
        "overrides": []
      }
    },
    {
      "id": 6,
      "title": "HTTP Rate by Route",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "victoriametrics"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 4
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(ahara_http_server_request_count_total{service_name=~\"linkdrop.*\"}[$__rate_interval])) by (http_request_method, url_path, operation_outcome)",
          "legendFormat": "{{http_request_method}} {{url_path}} {{operation_outcome}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        },
        "overrides": []
      }
    },
    {
      "id": 7,
      "title": "Slowest Operations",
      "type": "table",
      "datasource": {
        "type": "prometheus",
        "uid": "victoriametrics"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 12
      },
      "targets": [
        {
          "refId": "A",
          "expr": "topk(20, sum(rate(ahara_operation_duration_ms_sum{service_name=~\"linkdrop.*\"}[$__rate_interval])) by (operation_name) / clamp_min(sum(rate(ahara_operation_duration_ms_count{service_name=~\"linkdrop.*\"}[$__rate_interval])) by (operation_name), 1))",
          "format": "table",
          "instant": true
        }
      ]
    },
    {
      "id": 8,
      "title": "Log Investigation",
      "type": "text",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 12
      },
      "options": {
        "mode": "markdown",
        "content": "Use Grafana's native log tools for debugging instead of the embedded dashboard stream.\n\n- [Open Logs Drilldown](/a/grafana-lokiexplore-app/explore) for queryless browsing by service, labels, fields, volume, and patterns.\n- [Open Linkdrop logs in Explore](/explore?orgId=1&left=%7B%22datasource%22%3A%7B%22type%22%3A%22loki%22%2C%22uid%22%3A%22loki%22%7D%2C%22queries%22%3A%5B%7B%22refId%22%3A%22A%22%2C%22expr%22%3A%22%7Bservice_name%3D~%5C%22linkdrop.*%5C%22%7D%22%7D%5D%2C%22range%22%3A%7B%22from%22%3A%22now-6h%22%2C%22to%22%3A%22now%22%7D%7D) for the raw Loki query."
      }
    }
  ]
}
