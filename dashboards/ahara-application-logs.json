{
  "id": null,
  "uid": "ahara-application-logs",
  "title": "Ahara Application Logs",
  "tags": ["ahara", "logs", "application"],
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "schemaVersion": 39,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "links": [
    {
      "title": "Ahara dashboards",
      "type": "dashboards",
      "tags": ["ahara"],
      "asDropdown": true,
      "includeVars": true,
      "keepTime": true,
      "icon": "apps"
    }
  ],
  "description": "Product/service logs only. EC2 host and network logs (nginx, sshd, kernel, WireGuard, etc.) live on the separate Ahara Infrastructure Logs dashboard.",
  "templating": {
    "list": [
      {
        "name": "service_name",
        "label": "Service",
        "type": "query",
        "datasource": { "type": "loki", "uid": "loki" },
        "definition": "label_values({service_name!=\"ahara-ec2\"}, service_name)",
        "query": { "label": "service_name", "refId": "service_name", "stream": "{service_name!=\"ahara-ec2\"}", "type": 1 },
        "includeAll": true,
        "multi": true,
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "allValue": ".+",
        "refresh": 2,
        "sort": 1
      },
      {
        "name": "level",
        "label": "Level",
        "type": "query",
        "datasource": { "type": "loki", "uid": "loki" },
        "definition": "label_values(level)",
        "query": { "label": "level", "refId": "level", "stream": "", "type": 1 },
        "includeAll": true,
        "multi": true,
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "allValue": ".*",
        "refresh": 2,
        "sort": 1
      },
      {
        "name": "search",
        "label": "Line filter",
        "type": "textbox",
        "query": "",
        "current": { "selected": false, "text": "", "value": "" }
      }
    ]
  },
  "panels": [
    {
      "id": 100,
      "type": "row",
      "title": "Overview",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "id": 1,
      "title": "Log Lines/sec",
      "type": "stat",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "targets": [
        { "refId": "A", "expr": "sum(rate({service_name=~\"$service_name\", service_name!=\"ahara-ec2\", level=~\"$level\"} [$__rate_interval]))", "legendFormat": "lines/sec" }
      ],
      "fieldConfig": { "defaults": { "unit": "ops", "decimals": 2 }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" }
    },
    {
      "id": 2,
      "title": "Warn + Error Lines/sec",
      "type": "stat",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "targets": [
        { "refId": "A", "expr": "sum(rate({service_name=~\"$service_name\", service_name!=\"ahara-ec2\", level=~\"(?i)warn.*|error.*|err|fatal|critical\"} [$__rate_interval]))", "legendFormat": "warn+error/sec" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops", "decimals": 2, "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 0.05 }, { "color": "red", "value": 0.5 } ] } },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" }
    },
    {
      "id": 3,
      "title": "Services Logging",
      "type": "stat",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "targets": [
        { "refId": "A", "expr": "count(sum by (service_name) (count_over_time({service_name=~\"$service_name\", service_name!=\"ahara-ec2\", level=~\"$level\"} [$__range])))", "legendFormat": "services" }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 0 }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "none" }
    },
    {
      "id": 4,
      "title": "Total Lines (range)",
      "type": "stat",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "targets": [
        { "refId": "A", "expr": "sum(count_over_time({service_name=~\"$service_name\", service_name!=\"ahara-ec2\", level=~\"$level\"} [$__range]))", "legendFormat": "lines" }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 0 }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "none" }
    },
    {
      "id": 5,
      "title": "Log Volume by Service",
      "type": "timeseries",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 5 },
      "targets": [
        { "refId": "A", "expr": "sum by (service_name) (count_over_time({service_name=~\"$service_name\", service_name!=\"ahara-ec2\", level=~\"$level\"} [$__interval]))", "legendFormat": "{{service_name}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "bars", "fillOpacity": 60, "stacking": { "mode": "normal" }, "showPoints": "never" } }, "overrides": [] }
    },
    {
      "id": 6,
      "title": "Log Volume by Level",
      "type": "timeseries",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 5 },
      "targets": [
        { "refId": "A", "expr": "sum by (level) (count_over_time({service_name=~\"$service_name\", service_name!=\"ahara-ec2\", level=~\"$level\"} [$__interval]))", "legendFormat": "{{level}}" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "drawStyle": "bars", "fillOpacity": 70, "stacking": { "mode": "normal" }, "showPoints": "never" } },
        "overrides": [
          { "matcher": { "id": "byRegexp", "options": "(?i).*(error|err|fatal|critical).*" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } } ] },
          { "matcher": { "id": "byRegexp", "options": "(?i).*warn.*" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "yellow" } } ] },
          { "matcher": { "id": "byRegexp", "options": "(?i).*info.*" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } } ] }
        ]
      }
    },
    {
      "id": 7,
      "title": "Top Services by Volume",
      "type": "table",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 12 },
      "targets": [
        { "refId": "A", "expr": "topk(15, sum by (service_name) (count_over_time({service_name=~\"$service_name\", service_name!=\"ahara-ec2\", level=~\"$level\"} [$__range])))", "instant": true }
      ],
      "transformations": [
        { "id": "organize", "options": { "excludeByName": { "Time": true }, "renameByName": { "Value": "lines", "service_name": "Service" } } },
        { "id": "sortBy", "options": { "fields": "", "sort": [ { "field": "lines", "desc": true } ] } }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "filterable": true },
          "links": [
            { "title": "Service detail: ${__data.fields.Service}", "url": "/d/ahara-service-detail?var-service=${__data.fields.Service}&${__url_time_range}" },
            { "title": "Traces for ${__data.fields.Service}", "url": "/d/ahara-traces?var-service=${__data.fields.Service}&${__url_time_range}" }
          ]
        },
        "overrides": []
      }
    },
    {
      "id": 200,
      "type": "row",
      "title": "Logs",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 20 }
    },
    {
      "id": 8,
      "title": "Log Stream",
      "type": "logs",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 18, "w": 24, "x": 0, "y": 21 },
      "targets": [
        { "refId": "A", "expr": "{service_name=~\"$service_name\", service_name!=\"ahara-ec2\", level=~\"$level\"} |~ `(?i)$search`" }
      ],
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showCommonLabels": false,
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      }
    }
  ]
}
