{
  "id": null,
  "uid": "ahara-observability-stack",
  "title": "Ahara Pipeline Health",
  "tags": ["ahara", "observability", "pipeline"],
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "schemaVersion": 39,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "links": [
    {
      "title": "Ahara dashboards",
      "type": "dashboards",
      "tags": ["ahara"],
      "asDropdown": true,
      "includeVars": true,
      "keepTime": true,
      "icon": "apps"
    }
  ],
  "panels": [
    {
      "id": 100,
      "type": "row",
      "title": "Scrape Targets",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "id": 1,
      "title": "Target Health (up)",
      "type": "state-timeline",
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "gridPos": { "h": 6, "w": 16, "x": 0, "y": 1 },
      "targets": [
        { "refId": "A", "expr": "up", "legendFormat": "{{job}}" }
      ],
      "options": { "mergeValues": true, "showValue": "never", "rowHeight": 0.9 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 1 } ] }
        },
        "overrides": []
      }
    },
    {
      "id": 2,
      "title": "Targets Down",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 1 },
      "targets": [
        { "refId": "A", "expr": "count(up == 0) or vector(0)", "legendFormat": "down" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "decimals": 0, "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 1 } ] } },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" }
    },
    {
      "id": 200,
      "type": "row",
      "title": "Trace Pipeline (Tempo)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 7 }
    },
    {
      "id": 3,
      "title": "Spans Received/sec",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        { "refId": "A", "expr": "sum(rate(tempo_distributor_spans_received_total[$__rate_interval]))", "legendFormat": "distributor received" },
        { "refId": "B", "expr": "sum(rate(tempo_receiver_accepted_spans[$__rate_interval]))", "legendFormat": "receiver accepted" }
      ],
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "fillOpacity": 10, "showPoints": "never" } }, "overrides": [] }
    },
    {
      "id": 4,
      "title": "Spans Discarded/sec",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        { "refId": "A", "expr": "sum(rate(tempo_discarded_spans_total[$__rate_interval])) by (reason)", "legendFormat": "{{reason}}" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops", "custom": { "fillOpacity": 20, "showPoints": "never" }, "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 0.001 } ] } },
        "overrides": []
      }
    },
    {
      "id": 300,
      "type": "row",
      "title": "Log Pipeline (Loki)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 16 }
    },
    {
      "id": 5,
      "title": "Loki Lines Received/sec",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 17 },
      "targets": [
        { "refId": "A", "expr": "sum(rate(loki_distributor_lines_received_total[$__rate_interval]))", "legendFormat": "lines/sec" }
      ],
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "fillOpacity": 10, "showPoints": "never" } }, "overrides": [] }
    },
    {
      "id": 6,
      "title": "Loki Bytes Received/sec",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 17 },
      "targets": [
        { "refId": "A", "expr": "sum(rate(loki_distributor_bytes_received_total[$__rate_interval]))", "legendFormat": "bytes/sec" }
      ],
      "fieldConfig": { "defaults": { "unit": "Bps", "custom": { "fillOpacity": 10, "showPoints": "never" } }, "overrides": [] }
    },
    {
      "id": 400,
      "type": "row",
      "title": "Metric Pipeline (VictoriaMetrics)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 25 }
    },
    {
      "id": 7,
      "title": "Rows Inserted/sec",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 26 },
      "targets": [
        { "refId": "A", "expr": "sum(rate(vm_rows_inserted_total[$__rate_interval])) by (type)", "legendFormat": "{{type}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "fillOpacity": 10, "showPoints": "never" } }, "overrides": [] }
    },
    {
      "id": 8,
      "title": "Active Time Series (cardinality)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 26 },
      "targets": [
        { "refId": "A", "expr": "sum(vm_rows{type=\"storage/inmemory\"}) or sum(vm_rows)", "legendFormat": "rows in storage" },
        { "refId": "B", "expr": "sum(rate(vm_new_timeseries_created_total[$__rate_interval]))", "legendFormat": "new series/sec" }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "fillOpacity": 0, "showPoints": "never" } }, "overrides": [] }
    },
    {
      "id": 500,
      "type": "row",
      "title": "Collectors (Alloy) — split by instance: local router vs AWS edge gateway",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 34 }
    },
    {
      "id": 9,
      "title": "Collector Receiver Accepted/sec",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 35 },
      "targets": [
        { "refId": "A", "expr": "sum(rate(otelcol_receiver_accepted_spans_total[$__rate_interval])) by (instance)", "legendFormat": "{{instance}} spans" },
        { "refId": "B", "expr": "sum(rate(otelcol_receiver_accepted_metric_points_total[$__rate_interval])) by (instance)", "legendFormat": "{{instance}} metric points" }
      ],
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "fillOpacity": 10, "showPoints": "never" } }, "overrides": [] }
    },
    {
      "id": 10,
      "title": "Collector Receiver Refused + Failed/sec",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 35 },
      "targets": [
        { "refId": "A", "expr": "sum(rate(otelcol_receiver_refused_spans_total[$__rate_interval])) by (instance)", "legendFormat": "{{instance}} refused spans" },
        { "refId": "B", "expr": "sum(rate(otelcol_receiver_failed_spans_total[$__rate_interval])) by (instance)", "legendFormat": "{{instance}} failed spans" },
        { "refId": "C", "expr": "sum(rate(otelcol_receiver_refused_metric_points_total[$__rate_interval])) by (instance)", "legendFormat": "{{instance}} refused metrics" },
        { "refId": "D", "expr": "sum(rate(otelcol_receiver_failed_metric_points_total[$__rate_interval])) by (instance)", "legendFormat": "{{instance}} failed metrics" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops", "custom": { "fillOpacity": 20, "showPoints": "never" }, "color": { "mode": "fixed", "fixedColor": "red" }, "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 0.001 } ] } },
        "overrides": []
      }
    },
    {
      "id": 11,
      "title": "Collector Exporter Sent vs Send-Failed Spans/sec",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 43 },
      "targets": [
        { "refId": "A", "expr": "sum(rate(otelcol_exporter_sent_spans_total[$__rate_interval])) by (instance)", "legendFormat": "{{instance}} sent" },
        { "refId": "B", "expr": "sum(rate(otelcol_exporter_send_failed_spans_total[$__rate_interval])) by (instance)", "legendFormat": "{{instance}} send-failed" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops", "custom": { "fillOpacity": 10, "showPoints": "never" } },
        "overrides": [
          { "matcher": { "id": "byRegexp", "options": ".*send-failed.*" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } } ] }
        ]
      }
    },
    {
      "id": 12,
      "title": "Collector Exporter Queue Utilization",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 43 },
      "targets": [
        { "refId": "A", "expr": "max(otelcol_exporter_queue_size) by (instance) / clamp_min(max(otelcol_exporter_queue_capacity) by (instance), 1)", "legendFormat": "{{instance}} queue used" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "min": 0, "max": 1, "custom": { "fillOpacity": 10, "showPoints": "never" }, "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 0.5 }, { "color": "red", "value": 0.85 } ] } },
        "overrides": []
      }
    },
    {
      "id": 13,
      "title": "Collector coverage",
      "type": "text",
      "gridPos": { "h": 3, "w": 24, "x": 0, "y": 51 },
      "options": {
        "mode": "markdown",
        "content": "Series are split by `instance`. The **local router** Alloy (`alloy:12345`) is scraped by vmagent in this stack. The **AWS edge gateway** Alloy only appears here if `ahara-infra` ships its `otelcol_*` self-metrics to this VictoriaMetrics; otherwise its own health is owned on the AWS side."
      }
    }
  ]
}
