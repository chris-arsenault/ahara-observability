OBSERVABILITY_UID=2401
OBSERVABILITY_GID=2401
GRAFANA_ADMIN_PASSWORD=local-placeholder
GRAFANA_COGNITO_CLIENT_ID=local-placeholder-client-id
GRAFANA_COGNITO_CLIENT_SECRET=local-placeholder-client-secret
GRAFANA_SECRET_KEY=local-placeholder-secret-key
INFLUXDB_ADMIN_PASSWORD=local-placeholder
INFLUXDB_ADMIN_TOKEN=local-placeholder-token
# Ingest gateway: public Cognito issuer/JWKS for M2M (client_credentials) JWT
# validation. No secret here — only producers hold the client id/secret.
# Replace <pool-id> with the ahara Cognito user pool id (us-east-1).
COGNITO_ISSUER=https://cognito-idp.us-east-1.amazonaws.com/us-east-1_placeholder
COGNITO_JWKS_URI=https://cognito-idp.us-east-1.amazonaws.com/us-east-1_placeholder/.well-known/jwks.json
INGEST_SCOPE=observability/ingest
